{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": ["uvx", "ty", "server"],
      "extensions": [".py", ".pyi"]
    }
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    },
    "bash": {
      "*": "allow",
      "gcloud secrets*": "allow",
      "git commit*": "ask",
      "git push*": "ask",
      "kubectl apply*": "ask",
      "kubectl patch*": "ask",
      "helm upgrade*": "ask",
      "terraform*": "ask",
      "tofu destroy*": "ask",
      "tofu apply*": "ask"
    }
  }
}
