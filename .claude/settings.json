{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": ""
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Read(*)",
      "Write(*)",
      "WebFetch(*)",
      "TodoRead(*)",
      "TodoWrite(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "Monitor(*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl patch *)",
      "Bash(helm upgrade *)",
      "Bash(terraform *)",
      "Bash(tofu destroy *)",
      "Bash(tofu apply *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "JSON=\"$(cat)\"; MSG=\"$(echo \"$JSON\" | jq -r '.message // \"\"')\"; echo \"$MSG\" | grep -qiE 'permission|approval|needs your' || exit 0; SID=\"$(echo \"$JSON\" | jq -r '.session_id // \"\"')\"; NAME=\"$(jq -rs --arg sid \"$SID\" 'map(select(.sessionId == $sid)) | .[0].name // \"Claude\"' ~/.claude/sessions/*.json 2>/dev/null)\"; MSG=\"[$NAME] $MSG\" osascript -e 'display notification (system attribute \"MSG\") with title \"Claude Code\" sound name \"Ping\"'; true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "SID=\"$(jq -r '.session_id // \"\"')\"; NAME=\"$(jq -rs --arg sid \"$SID\" 'map(select(.sessionId == $sid)) | .[0].name // \"Claude\"' ~/.claude/sessions/*.json 2>/dev/null)\"; MSG=\"$NAME is waiting\" osascript -e 'display notification (system attribute \"MSG\") with title \"Claude Code\" sound name \"Ping\"'; true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "outputStyle": "concise",
  "viewMode": "verbose",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "prefersReducedMotion": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "statusLine": {
    "type": "command",
    "command": "/Users/mathieu/.claude/statusline.sh",
    "refreshInterval": 10
  },
  "showTurnDuration": false,
  "terminalProgressBarEnabled": false
}
